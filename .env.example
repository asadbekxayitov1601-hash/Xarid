# Local Postgres for dev; in production use your Neon connection string, e.g.
# postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/xarid?sslmode=require
DATABASE_URL="postgresql://xarid:xarid@localhost:5432/xarid_dev"
# From @BotFather
TELEGRAM_BOT_TOKEN=""
# Public HTTPS URL of the deployed app (used in bot web_app buttons)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret for signing session cookies (any long random string)
SESSION_SECRET="change-me"
# Password for /admin
ADMIN_PASSWORD="change-me-too"
# Optional: protects /api/cron/* for external cron callers
CRON_SECRET=""
# Optional: your personal Telegram ID — receives the 23:30 unconfirmed-PO summary
ADMIN_TELEGRAM_ID=""
# Set to "1" to disable the in-process 22:00 cutoff scheduler (e.g. if you
# run the cutoff via an external cron instead)
DISABLE_CUTOFF_SCHEDULER=""

# --- Paynet merchant (JSON-RPC, single webhook URL: /api/payments/paynet) ---
PAYNET_SERVICE_ID=""
PAYNET_USERNAME=""
PAYNET_PASSWORD=""
# Payment link template; {orderId} and {amountTiyin} are substituted
PAYNET_PAY_URL_TEMPLATE=""

# --- Uzum Bank merchant (developer.uzumbank.uz) ---
UZUM_SERVICE_ID=""
UZUM_MERCHANT_USERNAME=""
UZUM_MERCHANT_PASSWORD=""
# Checkout link template from the Uzum cabinet; {orderId} and {amountTiyin}
# are substituted, e.g. "https://www.uzumbank.uz/open-service?serviceId=...&orderId={orderId}&amount={amountTiyin}"
UZUM_PAY_URL_TEMPLATE=""

# --- Clerk auth (OPTIONAL, additive — see docs/CLERK_AUTH.md) ---
# Clerk is ADDITIVE and ENV-GATED: leave these UNSET and the app builds and runs
# exactly as before on the existing phone+password + Telegram auth. Set BOTH the
# publishable and secret key (from dashboard.clerk.com → API Keys) to turn the
# Clerk sign-in/sign-up surface on at /sign-in and /sign-up.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
# Route overrides — defaults are /sign-in and /sign-up (the routes scaffolded
# in this repo). Only change if you move those pages.
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
