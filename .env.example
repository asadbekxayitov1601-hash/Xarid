# SQLite for local dev; switch to a Postgres URL (Supabase/Neon) in production
DATABASE_URL="file:./dev.db"
# From @BotFather
TELEGRAM_BOT_TOKEN=""
# Public HTTPS URL of the deployed app (used in bot web_app buttons)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret for signing session cookies (any long random string)
SESSION_SECRET="change-me"
# Password for /admin
ADMIN_PASSWORD="change-me-too"
# Optional: protects /api/cron/cutoff (Vercel sends it automatically when set)
CRON_SECRET=""
