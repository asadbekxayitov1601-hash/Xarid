# Local Postgres for dev; in production use your Neon connection string, e.g.
# postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/xarid?sslmode=require
DATABASE_URL="postgresql://xarid:xarid@localhost:5432/xarid_dev"
# From @BotFather
TELEGRAM_BOT_TOKEN=""
# Public HTTPS URL of the deployed app (used in bot web_app buttons)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret for signing session cookies (any long random string)
SESSION_SECRET="change-me"
# Password for /admin
ADMIN_PASSWORD="change-me-too"
# Optional: protects /api/cron/* for external cron callers
CRON_SECRET=""
# Optional: your personal Telegram ID — receives the 23:30 unconfirmed-PO summary
ADMIN_TELEGRAM_ID=""
# Set to "1" to disable the in-process 22:00 cutoff scheduler (e.g. if you
# run the cutoff via an external cron instead)
DISABLE_CUTOFF_SCHEDULER=""
