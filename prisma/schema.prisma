// PostgreSQL everywhere: Neon in production, local Postgres (or a Neon
// dev branch) for development.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Both buyers (restaurants) and suppliers. type: BUYER | SUPPLIER
model Organization {
  id        String   @id @default(cuid())
  type      String
  name      String
  district  String
  phone     String
  // Supplier staff link their Telegram by sending /start sup_<botCode> to the bot
  botCode   String   @unique @default(cuid())
  // Public-facing supplier profile (Agent 4). Both fields are nullable so the
  // additive `db push` is safe on existing dev sqlite + prod Postgres rows.
  about     String?
  logoUrl   String?
  createdAt DateTime @default(now())

  users          User[]
  offers         SupplierOffer[]
  orders         Order[]
  purchaseOrders PurchaseOrder[]
}

// role: OWNER | STAFF | ADMIN | DRIVER
model User {
  id           String   @id @default(cuid())
  phone        String?  @unique
  telegramId   BigInt?  @unique
  name         String?
  passwordHash String?  // scrypt salt:hash — only for web sign-in accounts
  role         String   @default("OWNER")
  orgId        String?
  org          Organization? @relation(fields: [orgId], references: [id])
  createdAt    DateTime @default(now())

  orders Order[]
  driver Driver?
}

// Canonical SKU, e.g. "Onion, yellow / kg". unit: KG | PIECE | LITER | BLOCK
model Product {
  id       String  @id @default(cuid())
  nameUz   String
  nameRu   String
  category String
  unit     String
  sortKey  Int     @default(0)
  imageUrl String? // uploaded photo (compressed data URL) or external URL

  offers SupplierOffer[]
}

// A supplier's price for a canonical SKU. Prices are integer UZS.
// price = what the buyer sees (take rate already inside),
// costPrice = what the supplier receives.
model SupplierOffer {
  id         String  @id @default(cuid())
  supplierId String
  supplier   Organization @relation(fields: [supplierId], references: [id])
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  price      Int
  costPrice  Int
  available  Boolean @default(true)
  minQty     Float   @default(0)

  items OrderItem[]

  @@unique([supplierId, productId])
}

// Delivery driver. Links their Telegram via /start drv_<botCode>.
model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String
  botCode   String   @unique @default(cuid())
  userId    String?  @unique
  user      User?    @relation(fields: [userId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  orders Order[]
}

// The buyer's single morning basket.
// status: PLACED | CONFIRMED | PARTIAL | DELIVERING | DELIVERED | CANCELLED
model Order {
  id           String   @id @default(cuid())
  buyerUserId  String
  buyerUser    User     @relation(fields: [buyerUserId], references: [id])
  buyerOrgId   String?
  buyerOrg     Organization? @relation(fields: [buyerOrgId], references: [id])
  buyerName    String
  buyerPhone   String
  address      String
  status       String   @default("PLACED")
  deliveryDate DateTime
  // Customer-chosen arrival window (Agent 2 / time-at-checkout). Nullable so
  // the additive `db push` is safe on existing Postgres rows. `deliveryDate`
  // carries the chosen day + start time; `deliverySlot` stores the human
  // window label, e.g. "06:00-08:00". Legacy/null orders fall back to the
  // historic fixed "06:00-10:00" morning window in the UI.
  deliverySlot String?
  total        Int
  driverId     String?
  driver       Driver?  @relation(fields: [driverId], references: [id])
  cashTaken    Int?
  podFileId    String?  // proof-of-delivery photo (Telegram file_id)
  paidAt       DateTime?
  createdAt    DateTime @default(now())

  items          OrderItem[]
  purchaseOrders PurchaseOrder[]
  payments       Payment[]
}

// An online payment attempt (Click or Uzum Bank). Amounts in UZS.
// status: PENDING | PAID | CANCELLED
model Payment {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  provider       String   // PAYNET | UZUM
  externalId     String   // provider's transaction id
  // Monotonic numeric id some providers require (Paynet providerTrnId).
  // Column name is historical; kept to avoid migrating live databases.
  seq            BigInt   @unique(map: "Payment_clickPrepareId_key") @default(autoincrement()) @map("clickPrepareId")
  amount         Int
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  paidAt         DateTime?

  @@unique([provider, externalId])
}

// Double-entry ledger. Account ids are structured strings:
//   BUYER_RECEIVABLE:<userId> | SUPPLIER_PAYABLE:<orgId> | REVENUE:MARGIN |
//   CASH:DRIVER:<driverId> | CASH:OFFICE | BANK:<provider>
// `key` makes every posting idempotent (re-running an event is a no-op).
model LedgerEntry {
  id        String   @id @default(cuid())
  key       String   @unique
  debit     String
  credit    String
  amount    Int
  orderId   String?
  memo      String?
  createdAt DateTime @default(now())
}

// A week of supplier payables marked as paid out.
model Payout {
  id          String   @id @default(cuid())
  supplierId  String
  periodStart DateTime
  periodEnd   DateTime
  amount      Int
  createdAt   DateTime @default(now())

  @@unique([supplierId, periodStart])
}

// Per-supplier slice of an Order, created by the 22:00 cutoff.
// status: SENT | CONFIRMED | REJECTED
model PurchaseOrder {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  supplierId String
  supplier   Organization @relation(fields: [supplierId], references: [id])
  status     String   @default("SENT")
  note       String?
  createdAt  DateTime @default(now())

  lines OrderItem[]

  @@unique([orderId, supplierId])
}

// Prices and quantities are snapshotted at order time; qtyActual is the
// weighed/accepted quantity recorded at delivery — invoicing uses qtyActual.
model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  poId      String?
  po        PurchaseOrder? @relation(fields: [poId], references: [id])
  offerId   String
  offer     SupplierOffer @relation(fields: [offerId], references: [id])
  qty       Float
  qtyActual Float?
  price     Int
  costPrice Int
}

// Xarid Go (Agent 5) — last reported driver position. One row per driver,
// upserted by the driver's device every ~10s while a job is active.
// Position is plain WGS-84 (lat, lng); accuracy is metres (optional).
model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String   @unique
  lat       Float
  lng       Float
  accuracy  Float?
  updatedAt DateTime @updatedAt
}

// Phase 0 lead capture from the landing page. role: BUYER | SUPPLIER
model Lead {
  id        String   @id @default(cuid())
  name      String
  phone     String
  role      String
  district  String?
  createdAt DateTime @default(now())
}
